{
  "runs_cold": 50,
  "runs_warm": 50,
  "prompt": "Reply with the single word: pong",
  "max_tokens": 16,
  "gateways": [
    {
      "name": "anthropic",
      "host": "api.anthropic.com",
      "path": "/v1/messages",
      "model": "claude-haiku-4-5",
      "auth_header": "x-api-key",
      "auth_value": "$ANTHROPIC_API_KEY",
      "extra_headers": {
        "anthropic-version": "2023-06-01"
      }
    },
    {
      "name": "vercel",
      "host": "ai-gateway.vercel.sh",
      "path": "/v1/chat/completions",
      "model": "anthropic/claude-haiku-4.5",
      "auth_value": "Bearer $AI_GATEWAY_API_KEY"
    },
    {
      "name": "openrouter",
      "host": "openrouter.ai",
      "path": "/api/v1/chat/completions",
      "model": "anthropic/claude-haiku-4.5",
      "auth_value": "Bearer $OPENROUTER_API_KEY"
    },
    {
      "name": "cloudflare",
      "host": "gateway.ai.cloudflare.com",
      "path": "/v1/$CLOUDFLARE_ACCOUNT_ID/$CLOUDFLARE_GATEWAY_ID/compat/chat/completions",
      "model": "anthropic/claude-haiku-4-5",
      "auth_header": "cf-aig-authorization",
      "auth_value": "Bearer $CLOUDFLARE_API_KEY"
    },
    {
      "name": "cloudflare-anthropic",
      "host": "gateway.ai.cloudflare.com",
      "path": "/v1/$CLOUDFLARE_ACCOUNT_ID/$CLOUDFLARE_GATEWAY_ID/anthropic/v1/messages",
      "model": "claude-haiku-4-5",
      "auth_header": "x-api-key",
      "auth_value": "$ANTHROPIC_API_KEY",
      "extra_headers": {
        "anthropic-version": "2023-06-01",
        "cf-aig-authorization": "Bearer $CLOUDFLARE_API_KEY"
      }
    }
  ]
}
